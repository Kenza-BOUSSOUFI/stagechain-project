# Développement local Hardhat : impose le réseau 31337 pour éviter les transactions sur un autre chain.
REACT_APP_CHAIN_ID=31337

# Avant d’uploader CV/LM (IPFS) : lancer api-files — cd api-files && npm start (port 4000).

# Les adresses des contrats viennent de useContract.js (déploiement Ignition local).
# Ne pas mettre REACT_APP_USE_DEPLOYED_ENV=1 sauf si vous pointez volontairement vers d’autres contrats.
