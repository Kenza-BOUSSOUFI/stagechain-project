# Copier vers .env.local si besoin (priorité sur .env.development)

# Réseau MetaMask attendu (31337 = nœud Hardhat local)
# REACT_APP_CHAIN_ID=31337

# En `npm start`, les adresses Hardhat du code (DEFAULT_ADDRESSES) sont utilisées par défaut,
# même si Windows a d’anciennes variables REACT_APP_*_ADDRESS. Pour forcer les adresses du .env :
# REACT_APP_USE_DEPLOYED_ENV=1

# Déploiement ailleurs (ex. Sepolia) : USE_DEPLOYED_ENV=1 + chainId + toutes les adresses.
# REACT_APP_ACCOUNT_MANAGER_ADDRESS=
# REACT_APP_OFFRE_MANAGER_ADDRESS=
# REACT_APP_CONVENTION_MANAGER_ADDRESS=

# API fichiers (CV/LM + JSON convention) : JWT dans api-files/.env uniquement.
# En dev, laisser vide : le front appelle /api/... sur le port 3000 (proxy → api-files :4000).
# Définir REACT_APP_API_FILES_URL seulement si l’API est sur un autre hôte (hors proxy).
# REACT_APP_API_FILES_URL=http://localhost:4000
