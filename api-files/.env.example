PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Pinata Cloud (IPFS public — fichiers visibles sous Files → Public)
# https://app.pinata.cloud/developers/keys → New Key → copier le JWT (affiché une seule fois)
PINATA_JWT=your_pinata_jwt_here

# Optionnel : sous-domaine du gateway dédié (ex. amethyst-xxx.mypinata.cloud)
# PINATA_GATEWAY=

# 1 = CID factices seulement si PINATA_JWT est vide (avec JWT valide → upload réel obligatoire)
ALLOW_MOCK_IPFS_CID=0

# Si le mode MOCK reste actif alors que ce fichier est correct : vérifiez qu’aucune variable
# ALLOW_MOCK_IPFS_CID ou PINATA_JWT n’est définie dans les variables d’environnement Windows
# (le serveur api-files écrase désormais avec ce .env au démarrage).

# ── MongoDB (optionnel — index / métadonnées conventions via /api/conventions)
# Sans MONGODB_URI : /api/conventions → 503
# Atlas : collez l’URI complète (utilisateur / mot de passe / cluster), une ligne, sans guillemets.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/stagechain?retryWrites=true&w=majority
# ou URI « standard » avec ssl=true selon votre cluster.
