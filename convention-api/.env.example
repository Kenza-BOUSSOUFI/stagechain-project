PORT=4000
CORS_ORIGIN=http://localhost:3000

# Production / démo réelle : JWT depuis https://app.pinata.cloud (API Keys)
PINATA_JWT=

# Développement sans compte Pinata : mettre 1 pour générer un CID factice (le lien ipfs.io ne résoudra pas)
# ALLOW_MOCK_IPFS_CID=1

# Optionnel : uniquement si MongoDB tourne (sinon commentez ou supprimez cette ligne)
# MONGODB_URI=mongodb://127.0.0.1:27017/stagechain
